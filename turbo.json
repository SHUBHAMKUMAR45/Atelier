{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "globalEnv": ["NODE_ENV", "PORT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["MONGODB_URI_TEST", "GEMINI_API_KEY", "OPENAI_API_KEY"]
    },
    "clean": {
      "cache": false
    }
  }
}
