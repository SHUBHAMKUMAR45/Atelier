{
  "name": "@ai-fashion/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/apps/api/src/index.js",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@ai-fashion/ai-core": "workspace:*",
    "@ai-fashion/shared": "workspace:*",
    "@clerk/backend": "^2.0.0",
    "@google/generative-ai": "^0.7.0",
    "cloudinary": "^2.2.0",
    "cors": "^2.8.5",
    "dompurify": "^3.1.5",
    "express": "^4.19.0",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsdom": "^24.0.0",
    "mongoose": "^8.9.0",
    "openai": "^4.40.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.0",
    "replicate": "^0.29.0",
    "xss": "^1.0.15",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "autocannon": "^7.15.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.0.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "testTimeout": 30000,
    "moduleNameMapper": {
      "^../../../../packages/shared/src/(.*)$": "<rootDir>/../../packages/shared/src/$1",
      "^../../../../packages/ai-core/src/(.*)$": "<rootDir>/../../packages/ai-core/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts"
    ],
    "projects": [
      {
        "displayName": "unit",
        "testMatch": [
          "**/tests/unit/**/*.test.ts"
        ],
        "preset": "ts-jest",
        "testEnvironment": "node",
        "moduleNameMapper": {
          "^../../../../packages/shared/src/(.*)$": "<rootDir>/../../packages/shared/src/$1",
          "^../../../../packages/ai-core/src/(.*)$": "<rootDir>/../../packages/ai-core/src/$1"
        }
      },
      {
        "displayName": "integration",
        "testMatch": [
          "**/tests/integration/**/*.test.ts",
          "**/tests/chaos/**/*.test.ts"
        ],
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testTimeout": 60000,
        "globalSetup": "<rootDir>/tests/integration/setup.ts",
        "moduleNameMapper": {
          "^../../../../packages/shared/src/(.*)$": "<rootDir>/../../packages/shared/src/$1",
          "^../../../../packages/ai-core/src/(.*)$": "<rootDir>/../../packages/ai-core/src/$1"
        }
      },
      {
        "displayName": "ai-validation",
        "testMatch": [
          "**/tests/ai-validation/**/*.test.ts"
        ],
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testTimeout": 60000,
        "globalSetup": "<rootDir>/tests/integration/setup.ts",
        "moduleNameMapper": {
          "^../../../../packages/shared/src/(.*)$": "<rootDir>/../../packages/shared/src/$1",
          "^../../../../packages/ai-core/src/(.*)$": "<rootDir>/../../packages/ai-core/src/$1"
        }
      },
      {
        "displayName": "security",
        "testMatch": [
          "**/tests/security/**/*.test.ts"
        ],
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testTimeout": 30000,
        "moduleNameMapper": {
          "^../../../../packages/shared/src/(.*)$": "<rootDir>/../../packages/shared/src/$1",
          "^../../../../packages/ai-core/src/(.*)$": "<rootDir>/../../packages/ai-core/src/$1"
        }
      },
      {
        "displayName": "qa",
        "testMatch": [
          "**/tests/qa/**/*.test.ts"
        ],
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testTimeout": 30000,
        "moduleNameMapper": {
          "^../../../../packages/shared/src/(.*)$": "<rootDir>/../../packages/shared/src/$1",
          "^../../../../packages/ai-core/src/(.*)$": "<rootDir>/../../packages/ai-core/src/$1"
        }
      }
    ]
  }
}