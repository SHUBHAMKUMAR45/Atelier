{
  "title": "AI Fashion Stylist — Production",
  "uid":   "ai-fashion-prod",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Request Rate (RPS)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(ai_fashion_http_requests_total[1m]))",
        "legendFormat": "RPS"
      }],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2, "type": "stat", "title": "Error Rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(ai_fashion_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(ai_fashion_http_requests_total[5m]))",
        "legendFormat": "Error %"
      }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "value": 0, "color": "green" },
            { "value": 0.01, "color": "yellow" },
            { "value": 0.05, "color": "red" }
          ]
        }
      }
    },
    {
      "id": 3, "type": "stat", "title": "P99 Latency (ms)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(ai_fashion_http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
        "legendFormat": "P99 ms"
      }]
    },
    {
      "id": 4, "type": "stat", "title": "Recommendations Today",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(increase(ai_fashion_recommendations_generated_total[24h]))",
        "legendFormat": "Total"
      }]
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP Request Rate by Status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (status_code) (rate(ai_fashion_http_requests_total[1m]))",
        "legendFormat": "{{status_code}}"
      }]
    },
    {
      "id": 6, "type": "timeseries", "title": "AI Provider Latency (P95)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(ai_fashion_ai_request_duration_seconds_bucket[5m])))",
        "legendFormat": "{{provider}}"
      }]
    },
    {
      "id": 7, "type": "timeseries", "title": "Queue Depth",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "ai_fashion_queue_depth",
        "legendFormat": "{{queue}}"
      }]
    },
    {
      "id": 8, "type": "timeseries", "title": "Circuit Breaker State",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "ai_fashion_circuit_breaker_state",
        "legendFormat": "{{provider}}"
      }],
      "options": {
        "custom": { "thresholds": { "mode": "absolute", "steps": [
          { "value": 0, "color": "green" },
          { "value": 1, "color": "yellow" },
          { "value": 2, "color": "red" }
        ]}}
      }
    },
    {
      "id": 9, "type": "stat", "title": "Hallucination Rejections (1h)",
      "gridPos": { "x": 0, "y": 20, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(increase(ai_fashion_hallucination_rejections_total[1h]))",
        "legendFormat": "Rejections"
      }]
    },
    {
      "id": 10, "type": "stat", "title": "Security Rejections (1h)",
      "gridPos": { "x": 6, "y": 20, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(increase(ai_fashion_security_rejections_total[1h]))",
        "legendFormat": "Rejections"
      }]
    },
    {
      "id": 11, "type": "stat", "title": "Auth Failures (1h)",
      "gridPos": { "x": 12, "y": 20, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(increase(ai_fashion_auth_failures_total[1h]))",
        "legendFormat": "Failures"
      }]
    },
    {
      "id": 12, "type": "stat", "title": "Quota Exceeded (1h)",
      "gridPos": { "x": 18, "y": 20, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(increase(ai_fashion_quota_exceeded_total[1h]))",
        "legendFormat": "Events"
      }]
    }
  ]
}
