# ─────────────────────────────────────────────────────────────────
# AI Fashion Stylist — API Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000

# ── MongoDB Atlas (REQUIRED — localhost will NOT work in production) ──
# 1. Create free cluster at https://cloud.mongodb.com
# 2. Click Connect → Drivers → copy connection string
# 3. Replace <password> with your database user password
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai-fashion-stylist?retryWrites=true&w=majority
MONGODB_DB_NAME=ai-fashion-stylist

# ── Clerk Auth ──────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Gemini AI (Primary) ─────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# ── OpenAI (Fallback) ───────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ── Replicate (Image generation) ────────────────────────────────────
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# ── Cloudinary (Image hosting) ──────────────────────────────────────
# Get from: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Weather (OpenWeatherMap) ─────────────────────────────────────────
# Get from: https://openweathermap.org/api (free tier)
WEATHER_API_KEY=your_weather_key

# ── Rate limiting ────────────────────────────────────────────────────
DAILY_QUOTA_LIMIT=5
GLOBAL_RATE_LIMIT_RPM=100

# ── Cache TTL ────────────────────────────────────────────────────────
CACHE_TTL_TEXT_HOURS=6
CACHE_TTL_TREND_HOURS=24
CACHE_TTL_WEATHER_MINS=30

# ── CORS origins (comma-separated) ─────────────────────────────────
# Add your Vercel/Netlify frontend URL here for production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,https://your-app.vercel.app

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Admin ────────────────────────────────────────────────────────────
ADMIN_METRICS_TOKEN=change-me-in-production
