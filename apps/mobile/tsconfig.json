{
  "extends": "../../packages/config/tsconfig/base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-native",
    "noEmit": true,
    "allowJs": true,
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@ai-fashion/shared": [
        "../../packages/shared/src"
      ],
      "@ai-fashion/shared/*": [
        "../../packages/shared/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
