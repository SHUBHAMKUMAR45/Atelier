# ─────────────────────────────────────────────────────────────────
# AI Fashion Stylist — Web Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── Clerk Authentication ─────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk routing — do not change these unless you rename pages
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/profile

# ── Backend API ──────────────────────────────────────────────────
# Local dev: http://localhost:4000
# Production: your Railway URL e.g. https://ai-fashion-api.railway.app
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Sentry Error Tracking ────────────────────────────────────────
# Get from: https://sentry.io → Create Project → Next.js
# Leave blank for local development (Sentry is disabled when NODE_ENV != production)
NEXT_PUBLIC_SENTRY_DSN=
